#!/usr/bin/env bash

# RaVN: Create a webapp launcher that opens directly in a specific browser.
# Useful for second accounts (separate Edge profile) without affecting omarchy webapps.
# Usage: ravn-browser-webapp-install <name> <url> <icon> [browser] [extra-args]

set -e

if (( $# < 3 )); then
  echo "Usage: ravn-browser-webapp-install <name> <url> <icon> [browser] [extra-args]" >&2
  exit 1
fi

FILE_NAME="$1"
URL="$2"
ICON_REF="$3"
BROWSER="${4:-${RAVN_ALT_BROWSER:-microsoft-edge-stable}}"
EXTRA_ARGS="${5:-}"

ICON_DIR="${HOME}/.local/share/applications/icons"
DESKTOP_FILE="${HOME}/.local/share/applications/${FILE_NAME}.desktop"

if [[ $ICON_REF == /* ]]; then
  ICON_PATH="$ICON_REF"
elif [[ $ICON_REF == *.* ]]; then
  ICON_PATH="${ICON_DIR}/${ICON_REF}"
else
  ICON_PATH="$ICON_REF"
fi

if ! command -v "$BROWSER" &>/dev/null; then
  echo "Error: browser not found: $BROWSER" >&2
  exit 1
fi

if [[ -n $EXTRA_ARGS ]]; then
  # shellcheck disable=SC2086
  EXEC_LINE="$BROWSER $EXTRA_ARGS --app=$URL"
else
  EXEC_LINE="$BROWSER --app=$URL"
fi

{
  echo "[Desktop Entry]"
  echo "Version=1.0"
  echo "Name=${FILE_NAME}"
  echo "Comment=${FILE_NAME}"
  echo "Exec=${EXEC_LINE}"
  echo "Terminal=false"
  echo "Type=Application"
  echo "Icon=${ICON_PATH}"
  echo "StartupNotify=true"
  echo "Categories=WebApps;Network;"
  echo "Keywords=web;webapp;browser;alt-account;"
} >"$DESKTOP_FILE"

chmod +x "$DESKTOP_FILE"