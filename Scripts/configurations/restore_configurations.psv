# RaVN configuration overlay. RaVN always takes precedence over any
# existing (e.g. upstream) resource at the destination; the prior file
# is backed up, then overwritten. P=single-file artifact, S=directory
# to sync recursively.
# flag|destination|artifact|owner
P|${HOME}/.config/waybar|config.jsonc|ravn-configuration
P|${HOME}/.config/waybar|style.css|ravn-configuration
P|${HOME}/.config/waybar|theme.css|ravn-configuration
P|${HOME}/.config/waybar|user-style.css|ravn-configuration
S|${HOME}/.local/share|waybar|ravn-configuration
