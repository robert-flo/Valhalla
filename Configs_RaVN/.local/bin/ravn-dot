#!/usr/bin/env bash
#
# ravn-dot - Professional Dotfiles Change Management TUI
#

set +e

CONFIGS_DIR="$HOME/Work/Valhalla/master/Configs"
EXCLUDES_FILE="$HOME/.config/RaVN_dotcfg_excludes"
RESTORE_CFG="${CONFIGS_DIR%/*}/Scripts/restore_cfg.psv"
DRY_RUN=false

readonly RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m' MAGENTA='\033[0;35m' CYAN='\033[0;36m'
readonly WHITE='\033[1;37m' GRAY='\033[0;90m' NC='\033[0m'

readonly ICON_CHECK="󰄬" ICON_CROSS="󰅖" ICON_WARN="󰀦" ICON_INFO="󰋼" ICON_GEAR="󰒓"

print_header() {
    echo ""
    echo -e "${CYAN}╭────────────────────────────────────────────────────────────╮${NC}"
    echo -e "${CYAN}│${NC}  ${WHITE}$1${NC}"
    echo -e "${CYAN}╰────────────────────────────────────────────────────────────╯${NC}"
}

print_section() {
    echo ""
    echo -e "${MAGENTA}  $1${NC}"
    echo -e "${GRAY}  ──────────────────────────────────────────────────────────${NC}"
}

print_success() { echo -e "  ${GREEN}${ICON_CHECK}${NC} $1"; }
print_error()   { echo -e "  ${RED}${ICON_CROSS}${NC} $1"; }
print_warn()    { echo -e "  ${YELLOW}${ICON_WARN}${NC} $1"; }
print_info()    { echo -e "  ${BLUE}${ICON_INFO}${NC} $1"; }

command_exists() { command -v "$1" > /dev/null 2>&1; }

# Prevent running with sudo / as root
if [[ $EUID -eq 0 ]]; then
    echo ""
    echo -e "${RED}✗ ERROR: Do not run ravn-dot with sudo or as root.${NC}"
    echo -e "${YELLOW}  This tool modifies files in your user home directory.${NC}"
    echo -e "${YELLOW}  Running it as root can cause permission issues and data loss.${NC}"
    echo ""
    exit 1
fi

validate_environment() {
    print_section "${ICON_GEAR} Validating Environment"
    [[ -d "$CONFIGS_DIR" ]] || {
                                 print_error "Configs not found"
                                                                  exit 1
  }
    print_success "Configs directory"
    [[ -f "$RESTORE_CFG" ]] || {
                                 print_error "Manifest not found"
                                                                   exit 1
  }
    print_success "Manifest"
    command_exists fzf || {
                            print_error "fzf required"
                                                        exit 1
  }
    print_success "fzf"
}

declare -a EXCLUDES=()
load_excludes() {
    [[ -f "$EXCLUDES_FILE" ]] && mapfile -t EXCLUDES < "$EXCLUDES_FILE"
}

is_excluded() {
    local f="$1"
                  for e in "${EXCLUDES[@]}"; do [[ "$f" == "$e" ]] && return 0; done
                                                                                      return 1
}

declare -a MANAGED_FILES=()
declare -a DIFFERENT_FILES=()

build_managed_files() {
    MANAGED_FILES=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        local flag path cfg
        # shellcheck disable=SC2034
        flag=$(awk -F'|' '{print $1}' <<< "$line" | tr -d ' ')
        path=$(awk -F'|' '{print $2}' <<< "$line")
        cfg=$(awk -F'|' '{print $3}' <<< "$line")

        [[ -z "$path" || -z "$cfg" ]] && continue

        local path_resolved
        path_resolved=$(eval echo "$path" 2> /dev/null || echo "")
        [[ -z "$path_resolved" ]] && continue

        for cfg_chk in $cfg; do
            [[ -z "$cfg_chk" ]] && continue
            local active="$path_resolved/$cfg_chk"
            local rel="${path_resolved#"$HOME"/}/$cfg_chk"
            local template="$CONFIGS_DIR/$rel"

            if [[ -f "$active" && -f "$template" ]]; then
                if ! is_excluded "$rel"; then
                    MANAGED_FILES+=("$rel|$active|$template")
        fi
      fi
    done
  done   < "$RESTORE_CFG"
}

detect_differences() {
    DIFFERENT_FILES=()
    for entry in "${MANAGED_FILES[@]}"; do
        IFS='|' read -r rel active template <<< "$entry"
        if ! diff -q "$template" "$active" > /dev/null 2>&1; then
            DIFFERENT_FILES+=("$entry")
    fi
  done
}

keep_clean() {
    local active="$1" template="$2" rel="$3"
    [[ "$DRY_RUN" == true ]] && {
                                  print_info "[DRY] Would keep: $rel"
                                                                       return 0
  }
    cp "$active" "$template" && print_success "Updated dotfiles copy from HOME: $rel"
}

overwrite_home() {
    local active="$1" template="$2" rel="$3"
    [[ "$DRY_RUN" == true ]] && {
                                  print_info "[DRY] Would overwrite: $rel"
                                                                            return 0
  }
    cp "$template" "$active" && print_success "Updated \$HOME copy from dotfiles: $rel"
}

view_diff() {
    local active="$1" template="$2"
    if command_exists hunk; then
        hunk diff "$template" "$active" 2> /dev/null ||
        git diff --no-index --color=always "$template" "$active" | less -R || true
  else
        git diff --no-index --color=always "$template" "$active" | less -R || true
  fi
}

resolve_with_meld() {
    local active="$1" template="$2"
    if command_exists meld; then
        meld "$template" "$active"
  else
        print_error "meld is not installed"
        read -rp "  Press enter to continue..."
  fi
}

resolve_with_nvim() {
    local active="$1" template="$2"
    if command_exists nvim; then
        nvim -d "$template" "$active"
  elif   command_exists vim; then
        vim -d "$template" "$active"
  else
        print_error "nvim or vim is not installed"
        read -rp "  Press enter to continue..."
  fi
}

file_menu() {
    local rel="$1" active="$2" template="$3"
    while true; do
        clear
        print_header "$rel"
        echo -e "  ${GRAY}HOME:${NC} $active"
        echo -e "  ${GRAY}REPO:${NC} $template"
        echo ""
        [[ "$DRY_RUN" == true ]] && print_warn "DRY-RUN"
        echo "  [k] Update our dotfiles copy (from current HOME)"
        echo "  [o] Update our \$HOME copy (from dotfiles)"
        echo "  [d] View diff"
        echo "  [m] Resolve with meld"
        echo "  [v] Resolve with nvim"
        echo "  [x] Exclude forever (~/.config/RaVN_dotcfg_excludes)"
        echo "  [s] Skip"
        echo "  [b] Back"
        echo ""
        read -rp "  > " -n 1 c
        echo ""
        case "$c" in
            k | K)
                 keep_clean "$active" "$template" "$rel"
                                                          read -rp "  Continue..."
                                                                                   ;;
            o | O)
                 overwrite_home "$active" "$template" "$rel"
                                                              read -rp "  Continue..."
                                                                                       ;;
            d | D)
                 view_diff "$active" "$template"
                                                  read -rp "  Press enter to continue..."
                                                                                          ;;
            m | M) resolve_with_meld "$active" "$template" ;;
            v | V) resolve_with_nvim "$active" "$template" ;;
            x | X)
                 echo "$rel" >> "$EXCLUDES_FILE"
                                                  return 0
                                                           ;;
            s | S | b | B) return 0 ;;
    esac
  done
}

run_tui() {
    build_managed_files
    detect_differences

    if ((${#DIFFERENT_FILES[@]} == 0)); then
        print_header "ravn-dot"
        print_success "No differences found"
        echo ""
        return 0
  fi

    while true; do
        clear
        print_header "ravn-dot"
        [[ "$DRY_RUN" == true ]] && print_warn "DRY-RUN"
        print_section "${#DIFFERENT_FILES[@]} files differ"
        echo ""

        local selected
        # shellcheck disable=SC2016
        selected=$(printf "%s\n" "${DIFFERENT_FILES[@]}" | cut -d'|' -f1 |
            fzf --height=85% --border \
                --header="Enter: manage file • ESC: exit" \
                --preview '
                    echo "  File: {}"
                    echo ""
                    echo "  HOME: $HOME/{}"
                    echo "  REPO: '"$CONFIGS_DIR"'/{}"
                    echo ""
                    echo "  Press Enter to manage this file"
                ' || true)

        [[ -z "$selected" ]] && break

        for entry in "${DIFFERENT_FILES[@]}"; do
            if [[ "$entry" == "$selected|"* ]]; then
                IFS='|' read -r rel active template <<< "$entry"
                file_menu "$rel" "$active" "$template"
                break
      fi
    done
        detect_differences
        ((${#DIFFERENT_FILES[@]} == 0)) && break
  done
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run | -n)
                          DRY_RUN=true
                                        shift
                                              ;;
            -h | --help)
                       echo "Usage: ravn-dot [--dry-run]"
                                                           exit 0
                                                                  ;;
            *) shift ;;
    esac
  done
}

main() {
    parse_args "$@"
    print_header "ravn-dot — Dotfiles Manager"
    [[ "$DRY_RUN" == true ]] && print_warn "DRY-RUN ENABLED"
    validate_environment
    load_excludes
    run_tui
    print_section "Finished"
    print_success "ravn-dot complete"
    echo ""
}

main "$@"
